{
  "name": "@folio/ld-folio-wrapper",
  "repository": "@folio/ui-ld-folio-wrapper",
  "version": "2.0.5",
  "description": "Linked Data Editor - Folio Wrapper",
  "main": "src/index.js",
  "publishConfig": {
    "registry": "https://repository.folio.org/repository/npm-folio/"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=12.20.1"
  },
  "scripts": {
    "start": "stripes serve",
    "build": "stripes build --output ./output",
    "build-mod-descriptor": "stripes mod descriptor --full --strict | jq '.[]' > module-descriptor.json ",
    "formatjs-compile": "stripes translate compile",
    "lint": "eslint .",
    "test": "npm run test:coverage",
    "test:unit": "jest --watch",
    "test:coverage": "jest --ci --coverage"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/eslint-parser": "^8.0.1",
    "@babel/plugin-proposal-class-properties": "^7.0.0",
    "@babel/plugin-proposal-decorators": "^8.0.2",
    "@babel/plugin-transform-runtime": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@folio/eslint-config-stripes": "^8.0.0",
    "@folio/stripes": "^10.0.0",
    "@folio/stripes-cli": "^4.0.0",
    "@folio/stripes-core": "^11.0.0",
    "@jest/globals": "^30.4.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^30.4.1",
    "chai": "^6.2.2",
    "core-js": "^3.6.4",
    "eslint": "^10.7.0",
    "identity-obj-proxy": "^3.0.0",
    "inflected": "^2.0.4",
    "jest": "^30.4.2",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-junit": "^17.0.0",
    "jsdom": "^29.1.1",
    "mocha": "^11.7.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-intl": "^10.1.17",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.1",
    "redux": "^5.0.1",
    "regenerator-runtime": "^0.14.1"
  },
  "dependencies": {
    "@folio/linked-data": "^2.0.4",
    "prop-types": "^15.6.0"
  },
  "resolutions": {
    "favicons-webpack-plugin": "6.0.0"
  },
  "peerDependencies": {
    "@folio/stripes": "^10.0.0",
    "react": "*",
    "react-intl": "^10.1.17",
    "react-router": "^5.2.0",
    "react-router-dom": "^7.18.1"
  },
  "stripes": {
    "actsAs": [
      "app"
    ],
    "displayName": "ui-ld-folio-wrapper.meta.title",
    "route": "/linked-data-editor",
    "home": "/linked-data-editor/search",
    "hasSettings": false,
    "icons": [
      {
        "name": "app",
        "alt": "Marigold",
        "title": "Marigold"
      }
    ],
    "okapiInterfaces": {
      "authority-source-files": "2.2",
      "browse-authorities": "1.0",
      "linked-data": "2.0",
      "linked-data-profile": "1.0",
      "search-authorities": "1.0",
      "search-facets": "1.0",
      "search-linked-data": "1.0",
      "source-storage-records": "3.4"
    },
    "permissionSets": [
      {
        "permissionName": "module.ld-folio-wrapper.enabled",
        "displayName": "Linked Data: Module is enabled",
        "visible": true,
        "subPermissions": []
      },
      {
        "permissionName": "ui-marigold.cataloger.all",
        "displayName": "Marigold: Cataloger permissions",
        "replaces": ["ui-linked-data.all"],
        "visible": true,
        "subPermissions": [
          "module.ld-folio-wrapper.enabled",
          "browse.authorities.collection.get",
          "inventory-storage.authority-source-files.collection.get",
          "linked-data.authority-assignment-check.post",
          "linked-data.hub.preview.get",
          "linked-data.hub.import.post",
          "linked-data.import.file.post",
          "linked-data.import.url.post",
          "linked-data.profiles.item.get",
          "linked-data.profiles.metadata.get",
          "linked-data.profiles.preferred.get",
          "linked-data.profiles.preferred.post",
          "linked-data.profiles.preferred.delete",
          "linked-data.profiles.settings.get",
          "linked-data.profiles.settings.post",
          "linked-data.profiles.settings.put",
          "linked-data.profiles.settings.delete",
          "linked-data.profiles.settings.list.get",
          "linked-data.profiles.settings.preferred.get",
          "linked-data.profiles.settings.preferred.post",
          "linked-data.profiles.settings.preferred.delete",
          "linked-data.resources.bib.delete",
          "linked-data.resources.bib.get",
          "linked-data.resources.bib.id.get",
          "linked-data.resources.bib.marc.get",
          "linked-data.resources.bib.post",
          "linked-data.resources.bib.put",
          "linked-data.resources.graph.get",
          "linked-data.resources.import.post",
          "linked-data.resources.preview.get",
          "linked-data.resources.rdf.get",
          "linked-data.resources.support-check.get",
          "linked-data.vocabularies.item.get",
          "search.authorities.collection.get",
          "search.facets.collection.get",
          "search.linked-data.work.collection.get",
          "search.linked-data.hub.collection.get",
          "source-storage.records.formatted.item.get"
        ]
      }
    ]
  }
}
